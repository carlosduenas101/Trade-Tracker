# Copy this file to .env and replace the placeholder values with your real credentials.
# Never commit the .env file to version control.

# KCEX API credentials
# Obtain these from the KCEX account dashboard under API Management.
KCEX_API_KEY=your_key_here
KCEX_API_SECRET=your_secret_here

# SQLite database path (relative to the backend directory)
# To use a different database, supply a full SQLAlchemy connection string,
# e.g. postgresql://user:password@localhost:5432/trading_tracker
DATABASE_URL=sqlite:///./trading_tracker.db

# CORS allowed origins — comma-separated, no trailing slash
# Add your frontend dev server URL here.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
